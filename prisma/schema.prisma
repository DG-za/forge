generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RunStatus {
  pending
  planning
  in_progress
  completed
  failed
}

enum IssueStatus {
  queued
  coding
  gates
  reviewing
  fixing
  done
  failed
  escalated
}

enum AgentRole {
  planner
  coder
  reviewer
}

model Run {
  id           String     @id @default(cuid())
  repo         String
  epicNumber   Int
  status       RunStatus  @default(pending)
  budgetUsd    Float?
  totalCostUsd Float      @default(0)
  planSummary  String?
  config       Json
  issues       Issue[]
  planTasks    PlanTask[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Issue {
  id           String      @id @default(cuid())
  run          Run         @relation(fields: [runId], references: [id])
  runId        String
  issueNumber  Int
  title        String
  status       IssueStatus @default(queued)
  costUsd      Float       @default(0)
  inputTokens  Int         @default(0)
  outputTokens Int         @default(0)
  agentLogs    AgentLog[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model PlanTask {
  id                 String   @id @default(cuid())
  run                Run      @relation(fields: [runId], references: [id])
  runId              String
  orderIndex         Int
  issueNumber        Int?
  title              String
  acceptanceCriteria String[]
  dependencies       Int[]
  complexity         String
  planVersion        Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([runId, orderIndex])
}

model AgentLog {
  id           String    @id @default(cuid())
  issue        Issue     @relation(fields: [issueId], references: [id])
  issueId      String
  role         AgentRole
  platform     String
  model        String
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  durationMs   Int
  result       String?
  createdAt    DateTime  @default(now())
}

enum MessageRole {
  user
  assistant
  tool
}

model ChatSession {
  id        String        @id @default(cuid())
  title     String?
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id         String      @id @default(cuid())
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId  String
  role       MessageRole
  content    String
  toolCallId String?
  toolName   String?
  createdAt  DateTime    @default(now())
}

model McpServer {
  id        String   @id @default(cuid())
  name      String
  command   String
  args      Json     @default("[]")
  env       Json     @default("{}")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
